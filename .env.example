# Database
DATABASE_URL=postgres://postgres:secret@localhost:5432/inker?sslmode=disable

# JWT Secret - generate a secure random string for production
JWT="your-secure-jwt-secret-here"

# OAuth - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI/ML Keys (optional)
GEMINI_KEY=your-gemini-api-key
YOUTUBE_API_KEY=your-youtube-api-key

# Application Settings (optional - defaults shown)
# DEBUG=false
# FRONTEND_URL=http://localhost:3001
# BACKEND_URL=http://localhost:3000
# REDIRECT_DEFAULT_AFTER_PROVIDER=http://localhost:3001
